# ─────────────────────────────────────────────────────────────────────────
# The ONLY place the API URL is configured. No URLs are hardcoded in the code.
# ─────────────────────────────────────────────────────────────────────────
#
# Local development (default): point at the local mock API (`npm run api`).
EXPO_PUBLIC_API_URL=http://localhost:4000
#
# Production on Vercel: the build clears this (see scripts/vercel-build.mjs) so
# the hosted site calls its own same-origin /api serverless functions.
#
# Standalone APK (Mode 1): leave empty — the app ships with a bundled catalog
# and works fully offline with no server.
#   EXPO_PUBLIC_API_URL=
#
# APK connected to a live server (Mode 2, optional): set your deployed URL, e.g.
#   EXPO_PUBLIC_API_URL=https://your-demo.vercel.app
